<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Seed-VC Comparison Report</title>
  <style>
    :root {
      --bg: #f5efe7;
      --panel: rgba(255, 253, 248, 0.96);
      --ink: #1f2937;
      --muted: #6b7280;
      --line: #ddd3c6;
      --accent: #0f766e;
      --accent-soft: #d8f3ef;
      --warn: #b45309;
      --bad: #b91c1c;
      --shadow: 0 12px 28px rgba(17, 24, 39, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Source Sans 3", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top right, rgba(15, 118, 110, 0.10), transparent 25%),
        linear-gradient(180deg, #faf7f2 0%, var(--bg) 100%);
    }
    .wrap {
      max-width: 1480px;
      margin: 0 auto;
      padding: 24px;
    }
    .hero, .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }
    .hero {
      padding: 24px;
      margin-bottom: 16px;
      background: linear-gradient(135deg, rgba(255, 245, 214, 0.92), rgba(216, 243, 239, 0.96));
    }
    h1 {
      margin: 0 0 8px;
      font-size: 34px;
    }
    .meta, .run-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 16px;
      color: var(--muted);
      font-size: 14px;
    }
    .metric-grid, .run-grid {
      display: grid;
      gap: 12px;
      margin: 16px 0;
    }
    .metric-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
    .run-grid {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    .metric-card, .run-card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px;
      box-shadow: var(--shadow);
    }
    .metric-card.active {
      border-color: rgba(15, 118, 110, 0.45);
      background: linear-gradient(180deg, rgba(216, 243, 239, 0.75), rgba(255, 255, 255, 0.92));
    }
    .eyebrow {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .value {
      font-size: 28px;
      font-weight: 700;
      margin-top: 4px;
    }
    .run-card h2 {
      margin: 0 0 8px;
      font-size: 22px;
    }
    .checkpoint {
      font-family: "Fira Code", monospace;
      font-size: 12px;
      color: var(--muted);
      overflow-wrap: anywhere;
      margin-bottom: 8px;
    }
    .run-metric-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .mini-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px;
      background: rgba(255, 255, 255, 0.65);
    }
    .mini-card .mini-value {
      font-size: 20px;
      font-weight: 700;
    }
    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: end;
      padding: 16px;
      margin-bottom: 14px;
    }
    .controls label {
      display: flex;
      flex-direction: column;
      gap: 4px;
      color: var(--muted);
      font-size: 13px;
    }
    select, input, button {
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 9px 11px;
      font: inherit;
      background: white;
      color: var(--ink);
    }
    button {
      cursor: pointer;
      background: var(--accent-soft);
      color: #0b5c55;
      font-weight: 700;
    }
    .table-wrap {
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1280px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    thead { background: #f2ede5; }
    th, td {
      padding: 12px;
      border-bottom: 1px solid #ece4d8;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }
    th {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #475467;
    }
    .file-label {
      font-weight: 700;
      margin-bottom: 6px;
    }
    .metric-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 12px;
      font-weight: 700;
      background: var(--accent-soft);
      color: #0b5c55;
      margin: 0 8px 8px 0;
    }
    .metric-pill.na {
      background: #f3f4f6;
      color: var(--muted);
    }
    .metric-pill.warn {
      background: #fff7ed;
      color: var(--warn);
    }
    .metric-pill.bad {
      background: #fee2e2;
      color: var(--bad);
    }
    .delta-positive { color: #166534; }
    .delta-negative { color: #9a3412; }
    .status {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
      margin-top: 6px;
    }
    .status.error { color: var(--bad); }
    audio {
      width: 190px;
      max-width: 100%;
      display: block;
      margin-top: 6px;
    }
    @media (max-width: 900px) {
      .wrap { padding: 12px; }
      h1 { font-size: 28px; }
      audio { width: 150px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <h1>Seed-VC Evaluation Comparison</h1>
      <div class="meta">
        <span>Generated: {{ generated_at }}</span>
        <span>Total rows: {{ rows|length }}</span>
        <span>Default metric: {{ default_metric_key }}</span>
      </div>
    </section>

    <section class="metric-grid">
      {% for metric in metrics %}
      <article class="metric-card" data-metric-card="{{ metric.key }}">
        <div class="eyebrow">{{ metric.category }}</div>
        <div class="value">{{ metric.label }}</div>
        <div class="status">{{ metric.description }}</div>
        <div class="status">{{ metric.direction }} is better</div>
      </article>
      {% endfor %}
    </section>

    <section class="run-grid">
      {% for run in runs %}
      <article class="run-card">
        <h2>{{ run.label }}</h2>
        <div class="checkpoint">{{ run.checkpoint or "Checkpoint unavailable" }}</div>
        <div class="run-meta">
          <span>Cache: {{ run.cache_name }}</span>
          <span>Generated: {{ run.generated_count }}</span>
          <span>Total: {{ run.total }}</span>
          <span><a href="{{ run.metrics_manifest }}">metrics_manifest.json</a></span>
          <span><a href="{{ run.results_manifest }}">results_manifest.json</a></span>
        </div>
        <div class="run-metric-strip">
          {% for metric in metrics %}
          {% set summary = run.metrics.get(metric.key, {}) %}
          <div class="mini-card">
            <div class="eyebrow">{{ metric.short_label }}</div>
            <div class="mini-value">{{ summary.mean_display or "N/A" }}</div>
            <div class="status">Rows scored: {{ summary.scored or 0 }}</div>
          </div>
          {% endfor %}
        </div>
      </article>
      {% endfor %}
    </section>

    <section class="panel controls">
      <label>
        Metric focus
        <select id="metricSelect"></select>
      </label>
      <label>
        Sort rows
        <select id="sortOrder">
          <option value="delta-best">Largest improvement</option>
          <option value="delta-worst">Largest regression</option>
          <option value="run-b-best">Best Run B</option>
          <option value="run-a-best">Best Run A</option>
          <option value="original">Original order</option>
        </select>
      </label>
      <label>
        Require both runs
        <select id="requireBoth">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </label>
      <label>
        Status filter
        <select id="statusFilter">
          <option value="all">All rows</option>
          <option value="ok">Only scored in both runs</option>
          <option value="issues">Only rows with issues</option>
        </select>
      </label>
      <button id="clearFilters" type="button">Reset</button>
      <span id="visibleCount" class="status"></span>
    </section>

    <section class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Item</th>
            <th>Source</th>
            <th>Target</th>
            <th>Run A</th>
            <th>Run B</th>
            <th>Delta</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </section>
  </div>

  <script>
    const defaultMetricKey = {{ default_metric_key|tojson }};
    const metrics = {{ metrics|tojson }};
    const rows = {{ rows|tojson }};
    const metricSelect = document.getElementById('metricSelect');
    const sortOrder = document.getElementById('sortOrder');
    const requireBoth = document.getElementById('requireBoth');
    const statusFilter = document.getElementById('statusFilter');
    const clearFilters = document.getElementById('clearFilters');
    const tbody = document.getElementById('rows');
    const visibleCount = document.getElementById('visibleCount');

    for (const metric of metrics) {
      const option = document.createElement('option');
      option.value = metric.key;
      option.textContent = `${metric.label} (${metric.direction} is better)`;
      if (metric.key === defaultMetricKey) option.selected = true;
      metricSelect.appendChild(option);
    }

    function metricMeta(key) {
      return metrics.find((metric) => metric.key === key) || { key, label: key, short_label: key, direction: 'higher' };
    }

    function runMetric(run, key) {
      if (!run) return { display: 'N/A', status: 'missing_run', error: null, value: null, sort_value: null };
      return run.metrics[key] || { display: 'N/A', status: 'not_run', error: null, value: null, sort_value: null };
    }

    function metricPillClass(cell) {
      if (cell.status === 'ok') return 'metric-pill';
      if (cell.status === 'disabled' || cell.status === 'unavailable' || cell.status === 'not_run' || cell.status === 'missing_run') return 'metric-pill na';
      if (cell.status === 'missing_generated') return 'metric-pill warn';
      return 'metric-pill bad';
    }

    function deltaClass(value) {
      if (value === null) return 'metric-pill na';
      if (value > 0) return 'metric-pill delta-positive';
      if (value < 0) return 'metric-pill delta-negative';
      return 'metric-pill';
    }

    function renderRows() {
      const selectedMetric = metricSelect.value;
      for (const card of document.querySelectorAll('[data-metric-card]')) {
        card.classList.toggle('active', card.dataset.metricCard === selectedMetric);
      }

      const filtered = rows.filter((row) => {
        const runA = runMetric(row.run_a, selectedMetric);
        const runB = runMetric(row.run_b, selectedMetric);
        if (requireBoth.value === 'yes' && !row.has_both_runs) return false;
        if (statusFilter.value === 'ok') return runA.status === 'ok' && runB.status === 'ok';
        if (statusFilter.value === 'issues') return runA.status !== 'ok' || runB.status !== 'ok';
        return true;
      });

      if (sortOrder.value !== 'original') {
        filtered.sort((a, b) => {
          const aRunA = runMetric(a.run_a, selectedMetric);
          const aRunB = runMetric(a.run_b, selectedMetric);
          const bRunA = runMetric(b.run_a, selectedMetric);
          const bRunB = runMetric(b.run_b, selectedMetric);
          const aDelta = a.deltas[selectedMetric]?.value;
          const bDelta = b.deltas[selectedMetric]?.value;
          const score = (mode, left, right) => {
            if (left === null && right === null) return 0;
            if (left === null) return 1;
            if (right === null) return -1;
            return mode === 'desc' ? right - left : left - right;
          };
          if (sortOrder.value === 'delta-best') return score('desc', aDelta, bDelta);
          if (sortOrder.value === 'delta-worst') return score('asc', aDelta, bDelta);
          if (sortOrder.value === 'run-b-best') return score('desc', aRunB.sort_value, bRunB.sort_value);
          if (sortOrder.value === 'run-a-best') return score('desc', aRunA.sort_value, bRunA.sort_value);
          return 0;
        });
      }

      tbody.innerHTML = '';
      filtered.forEach((row, index) => {
        const runA = runMetric(row.run_a, selectedMetric);
        const runB = runMetric(row.run_b, selectedMetric);
        const delta = row.deltas[selectedMetric] || { display: 'N/A', value: null };
        const runAStrip = metrics.map((metric) => {
          const cell = runMetric(row.run_a, metric.key);
          return `<span class="${metricPillClass(cell)}">${metric.short_label}: ${cell.display}</span>`;
        }).join('');
        const runBStrip = metrics.map((metric) => {
          const cell = runMetric(row.run_b, metric.key);
          return `<span class="${metricPillClass(cell)}">${metric.short_label}: ${cell.display}</span>`;
        }).join('');

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${index + 1}</td>
          <td>
            <div class="file-label">${row.source_name}</div>
            <div class="status">target: ${row.target_name}</div>
          </td>
          <td>
            <div class="file-label">Source</div>
            <audio controls preload="none" src="${row.source_path || ''}"></audio>
          </td>
          <td>
            <div class="file-label">Target</div>
            <audio controls preload="none" src="${row.target_path || ''}"></audio>
          </td>
          <td>
            <div class="file-label">${metricMeta(selectedMetric).label}: ${runA.display}</div>
            <div class="status ${runA.error ? 'error' : ''}">status=${runA.status}${runA.error ? `<br>${runA.error}` : ''}</div>
            <div>${runAStrip}</div>
            ${row.run_a && row.run_a.generated_path ? `<audio controls preload="none" src="${row.run_a.generated_path}"></audio>` : '<div class="status">Generated audio unavailable</div>'}
          </td>
          <td>
            <div class="file-label">${metricMeta(selectedMetric).label}: ${runB.display}</div>
            <div class="status ${runB.error ? 'error' : ''}">status=${runB.status}${runB.error ? `<br>${runB.error}` : ''}</div>
            <div>${runBStrip}</div>
            ${row.run_b && row.run_b.generated_path ? `<audio controls preload="none" src="${row.run_b.generated_path}"></audio>` : '<div class="status">Generated audio unavailable</div>'}
          </td>
          <td>
            <div class="file-label">Run B - Run A</div>
            <div class="${deltaClass(delta.value)}">${delta.display}</div>
            <div class="status">Shown only when both runs have the selected metric.</div>
          </td>
        `;
        tbody.appendChild(tr);
      });

      visibleCount.textContent = `Showing ${filtered.length} / ${rows.length} rows for ${metricMeta(selectedMetric).label}`;
    }

    metricSelect.addEventListener('change', renderRows);
    sortOrder.addEventListener('change', renderRows);
    requireBoth.addEventListener('change', renderRows);
    statusFilter.addEventListener('change', renderRows);
    clearFilters.addEventListener('click', () => {
      metricSelect.value = defaultMetricKey;
      sortOrder.value = 'delta-best';
      requireBoth.value = 'no';
      statusFilter.value = 'all';
      renderRows();
    });

    renderRows();
  </script>
</body>
</html>
